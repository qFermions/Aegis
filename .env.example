# Environment-variable reference for Aegis scripts.
# The zero-dependency scripts do not auto-load .env; export these values in the
# current shell or configure them in CI. Never commit a populated env file.

# Used by scripts/security-audit.js
TENANT=[@Aegion_DOMAIN]
AUDITOR=[ADMIN_NAME]

# Enables tenant/org literal detection in scripts/pre-commit-check.js
AEGION_DOMAIN=
AEGION_ORG_NAME=

# Jira Service Management; keep the API token in the shell or secret manager
JIRA_SITE=[@Aegion_JIRA_URL]
JIRA_EMAIL=[admin@YOUR_DOMAIN]
JIRA_API_TOKEN=
JIRA_SERVICE_DESK_ID=
JIRA_REQUEST_TYPE_ID=

# Optional init-memory.js overrides; the default key derives from the Git root
MEMORY_DIR=
PROJECT_KEY=
